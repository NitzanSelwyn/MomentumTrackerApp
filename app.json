{
  "expo": {
    "name": "MomentumTracker",
    "slug": "MomentumTrackerApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "momentum-tracker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MomentumTracker needs your location to track your position during shifts.",
        "NSLocationWhenInUseUsageDescription": "MomentumTracker needs your location to show your position on the map.",
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "com.momentum.tracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.momentum.tracker"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MomentumTracker needs your location to track your position during shifts.",
          "locationWhenInUsePermission": "MomentumTracker needs your location to show your position on the map.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "MomentumTracker needs camera access to scan QR codes for joining organizations."
        }
      ]
    ]
  }
}
